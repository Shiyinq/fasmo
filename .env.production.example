# ==========================================
# FASMO PRODUCTION ENVIRONMENT TEMPLATE
# ==========================================
# Instructions:
# 1. Copy this file to .env on your server
# 2. Fill in ALL empty values
# 3. Use strong, unique passwords for everything

# --- CORE SETTINGS ---
ENV=prod
LOG_LEVEL=info
LOG_DESTINATION=file
LOG_PATH=/var/log/fasmo/

# --- URLS (CRITICAL - DO NOT USE LOCALHOST) ---
# Main App Domain
FRONTEND_URL=https://fasmo.app
# Public API Domain (Used by Frontend build)
PUBLIC_CLIENT_SIDE_API_BASE_URL=https://api.fasmo.app

# API Base URL (Used by Backend for internal logic)
API_BASE_URL=https://api.fasmo.app
# CORS Origins (Comma separated)
ORIGINS=https://fasmo.app,https://api.fasmo.app
# Cookie Domain (Set to apex domain for cross-subdomain support)
COOKIE_DOMAIN=fasmo.app

# --- SECURITY ---
# Generate a random 32+ character string (e.g. openssl rand -hex 32)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_MAX_AGE_DAYS=30

# --- DATABASE ---
# Root credentials (Required for production auth)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=ChangeThisExtremeleyLongPassword

# MONGODB_URI is handled internally by docker-compose
DB_NAME=fasmo
DB_MAX_POOL_SIZE=100

# --- OAUTH ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.fasmo.app/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.fasmo.app/auth/google/callback

# --- EMAIL (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@fasmo.app

# --- AUTH SECURITY & LIMITERS ---
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
# Rate limiting (requests per minute)
DEFAULT_REQUESTS_PER_MINUTE=60

# --- VERIFICATION & EXPIRATION ---
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
